name: build-mac-arm64

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: macos-14
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Show manifest plan
        run: python3 scripts/render_upgrade_plan.py --manifest manifests/current.json

      - name: Placeholder
        run: |
          echo "在这里接入私有构建逻辑："
          echo "- clone packaging repo"
          echo "- apply patch series"
          echo "- build Chromium.app"
          echo "- sign / notarize"
