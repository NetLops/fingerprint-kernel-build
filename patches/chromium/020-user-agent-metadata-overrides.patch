+    UpsertBrandVersion(&metadata->brand_full_version_list, "Google Chrome",
+                       full_version);
+    return;
+  }
+  if (brand == "edge") {
+    UpsertBrandVersion(&metadata->brand_version_list, "Microsoft Edge",
+                       major_version);
+    UpsertBrandVersion(&metadata->brand_full_version_list, "Microsoft Edge",
+                       full_version);
+    metadata->full_version = full_version;
+    return;
+  }
+  if (brand == "opera") {
+    UpsertBrandVersion(&metadata->brand_version_list, "Opera", major_version);
+    UpsertBrandVersion(&metadata->brand_full_version_list, "Opera",
+                       full_version);
+    metadata->full_version = full_version;
+    return;
+  }
+  if (brand == "vivaldi") {
+    UpsertBrandVersion(&metadata->brand_version_list, "Vivaldi", major_version);
