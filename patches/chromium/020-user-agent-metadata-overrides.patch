+  if (full_version.empty()) {
+    full_version = metadata->full_version;
+  }
+  if (full_version.empty()) {
+    return;
+  }
+
+  const std::string major_version = MajorVersionFrom(full_version);
+  if (brand == "chrome") {
+    UpsertBrandVersion(&metadata->brand_version_list, "Google Chrome",
