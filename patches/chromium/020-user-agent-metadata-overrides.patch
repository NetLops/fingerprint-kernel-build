+    metadata->platform_version =
+        custom_platform_version.empty() ? "6.0.0" : custom_platform_version;
+    metadata->architecture = "x86";
+  } else if (platform == "mac") {
+    metadata->platform = "macOS";
+    metadata->platform_version =
+        custom_platform_version.empty() ? "15.0.0" : custom_platform_version;
+    metadata->architecture = "arm";
+  }
+
+  if (!command_line->HasSwitch(switches::kFingerprintBrand)) {
+    return;
+  }
+
+  const std::string brand = base::ToLowerASCII(
+      command_line->GetSwitchValueASCII(switches::kFingerprintBrand));
+  std::string full_version =
