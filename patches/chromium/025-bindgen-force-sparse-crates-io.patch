diff --git a/tools/rust/build_bindgen.py b/tools/rust/build_bindgen.py
--- a/tools/rust/build_bindgen.py
+++ b/tools/rust/build_bindgen.py
@@ -55,6 +55,37 @@ EXCLUDED_TESTS = [
     'header_typedef_pointer_overlap_h'
 ]
 
+BINDGEN_CARGO_CONFIG = '''[source.crates-io]
+replace-with = "rsproxy-sparse"
+
+[source.rsproxy-sparse]
+registry = "sparse+https://rsproxy.cn/index/"
+
+[net]
+git-fetch-with-cli = false
+'''
+
+
+def ConfigureBindgenCargo():
+    """Keep bindgen's cargo build isolated from runner-global mirrors."""
+    cargo_config_dir = os.path.join(BINDGEN_SRC_DIR, '.cargo')
+    os.makedirs(cargo_config_dir, exist_ok=True)
+    cargo_config_path = os.path.join(cargo_config_dir, 'config.toml')
+    with open(cargo_config_path, 'w', encoding='utf-8') as cargo_config:
+        cargo_config.write(BINDGEN_CARGO_CONFIG)
+    print(f'Wrote bindgen cargo config: {cargo_config_path}')
+
+    for stale_path in (
+            os.path.join(CARGO_HOME_DIR, 'registry', 'index'),
+            os.path.join(CARGO_HOME_DIR, 'registry', 'cache'),
+    ):
+        if os.path.exists(stale_path):
+            shutil.rmtree(stale_path)
+
+
 def FetchNcurseswLibrary():
     assert sys.platform.startswith('linux')
     ncursesw_dir = os.path.join(LLVM_BUILD_TOOLS_DIR, 'ncursesw')
@@ -100,9 +131,11 @@ def RunCargo(cargo_args):
     clang_bins_dir = os.path.join(THIRD_PARTY_DIR, 'llvm-build', 'Release+Asserts', 'bin')
     llvm_dir = os.path.join(THIRD_PARTY_DIR, 'llvm-build', 'Release+Asserts')
 
+    ConfigureBindgenCargo()
     env = collections.defaultdict(str, os.environ)
     # Cargo normally stores files in $HOME. Override this.
     env['CARGO_HOME'] = CARGO_HOME_DIR
