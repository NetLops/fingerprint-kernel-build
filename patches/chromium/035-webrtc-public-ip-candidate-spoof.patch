+constexpr char kFingerprintWebRtcPublicIpSwitch[] =
+    "fingerprint-webrtc-public-ip";
+
+std::string GetFingerprintWebRtcPublicIpOverride() {
+  const base::CommandLine* command_line = base::CommandLine::ForCurrentProcess();
+  std::string public_ip =
+      command_line->GetSwitchValueASCII(kFingerprintWebRtcPublicIpSwitch);
+  if (public_ip.find_first_of(" \t\r\n") != std::string::npos) {
+    return std::string();
+  }
+  return public_ip;
+}
+
+bool IsCandidateLine(const std::string& line) {
+  return line.rfind("candidate:", 0) == 0 ||
+         line.rfind("a=candidate:", 0) == 0;
+}
+
+bool ShouldRewriteRelatedAddress(const std::string& address) {
+  return !address.empty() && address != "0.0.0.0" && address != "::";
+}
+
+std::string RewriteWebRtcCandidateLinePublicIp(const std::string& line,
+                                               const std::string& public_ip) {
+  if (public_ip.empty() || !IsCandidateLine(line)) {
+    return line;
+  }
+
+  const bool has_sdp_prefix = line.rfind("a=", 0) == 0;
+  const std::string prefix = has_sdp_prefix ? "a=" : "";
+  const std::string candidate = has_sdp_prefix ? line.substr(2) : line;
+
+  std::istringstream stream(candidate);
+  std::vector<std::string> tokens;
+  std::string token;
+  while (stream >> token) {
+    tokens.push_back(token);
+  }
+  if (tokens.size() < 6 || tokens[0].rfind("candidate:", 0) != 0) {
+    return line;
+  }
+
+  // candidate:<foundation> <component> <protocol> <priority> <address> <port>
+  tokens[4] = public_ip;
+  for (size_t i = 0; i + 1 < tokens.size(); ++i) {
+    if (tokens[i] == "raddr" && ShouldRewriteRelatedAddress(tokens[i + 1])) {
+      tokens[i + 1] = public_ip;
+    }
+  }
+
+  std::string rewritten = prefix;
+  for (size_t i = 0; i < tokens.size(); ++i) {
+    if (i > 0) {
+      rewritten.push_back(' ');
+    }
+    rewritten += tokens[i];
+  }
+  return rewritten;
+}
+
+std::string RewriteWebRtcCandidatePublicIps(const std::string& value) {
+  const std::string public_ip = GetFingerprintWebRtcPublicIpOverride();
+  if (public_ip.empty()) {
+    return value;
+  }
+
+  std::string rewritten;
+  size_t line_start = 0;
+  while (line_start < value.size()) {
+    size_t line_end = value.find('\n', line_start);
+    const bool has_newline = line_end != std::string::npos;
+    if (!has_newline) {
+      line_end = value.size();
+    }
+
+    std::string line = value.substr(line_start, line_end - line_start);
+    const bool has_carriage_return =
+        !line.empty() && line.back() == '\r';
+    if (has_carriage_return) {
+      line.pop_back();
+    }
+
+    rewritten += RewriteWebRtcCandidateLinePublicIp(line, public_ip);
+    if (has_carriage_return) {
+      rewritten.push_back('\r');
+    }
+    if (has_newline) {
+      rewritten.push_back('\n');
+    }
+    line_start = line_end + (has_newline ? 1 : 0);
+  }
+  return rewritten;
+}
